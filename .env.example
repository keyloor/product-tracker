# Copia este archivo a ".env" para pruebas locales (NO subir a git).
# En GitHub estos valores van como Actions secrets.

# --- Tienda Ecwid ---
# Id numerico de la tienda y token publico de storefront (solo lectura).
ECWID_STORE_ID=
ECWID_PUBLIC_TOKEN=

# --- Correo (Resend) ---
# API key de Resend: https://resend.com/api-keys
RESEND_API_KEY=

# Correo donde quieres recibir las alertas.
MAIL_TO=

# Opcional: remitente. Sin dominio verificado, Resend solo envia desde
# onboarding@resend.dev y unicamente al correo de tu cuenta Resend.
# MAIL_FROM=Alertas <onboarding@resend.dev>

# Opcional: nombre que aparece en el asunto y cuerpo del correo.
# STORE_NAME=
